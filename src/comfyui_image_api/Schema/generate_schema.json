{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Generate Flux.1-Dev Image Payload",
  "type": "object",
  "properties": {
    "prompt": {
      "type": "string",
      "description": "Text prompt for generating the image",
      "minLength": 1
    },
    "steps": {
      "type": "integer",
      "default": 30,
      "minimum": 1,
      "description": "The number of steps to process"
    },
    "seed": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9223372036854775807,
      "description": "Seed for generating the image, if not provided, it will be randomly generated"
    },
    "width": {
      "type": "integer",
      "default": 512,
      "description": "Width of the generated image",
      "minimum": 64,
      "maximum": 1024
    },
    "height": {
      "type": "integer",
      "default": 512,
      "description": "Height of the generated image",
      "minimum": 64,
      "maximum": 1024
    },
    "cfg": {
      "type": "number",
      "default": 4.0,
      "description": "Classifier-free guidance value",
      "minimum": 1,
      "maximum": 30
    },
    "denoise": {
      "type": "number",
      "default": 1.0,
      "description": "Denoise strength",
      "minimum": 1,
      "maximum": 30
    },
    "content_filter": {
      "type": "object",
      "description": "Optional NSFW filter settings",
      "properties": {
        "level": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2,
          "default": 2,
          "description": "NSFW severity level required to trigger filtering, 0: no filter, 1: NSFW filter, 2: Explicit filter"
        },
        "probability": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "default": 0.5,
          "description": "Minimum score probability threshold to include label"
        },
        "blur": {
          "type": "boolean",
          "default": true,
          "description": "Whether to apply Gaussian blur to content that matches the filtering criteria"
        },
        "gaussian_blur_minimum": {
          "type": "number",
          "minimum": 0,
          "default": 20,
          "description": "Minimum number of pixels to use as a blur radius"
        },
        "gaussian_blur_fraction": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "default": 0.05,
          "description": "Fraction of the largest image dimension to use for Gaussian blur radius"
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["prompt"],
  "additionalProperties": false
}
